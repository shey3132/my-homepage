# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# The prompt that defines the AI's personality
SYSTEM_PROMPT="אתה עוזר טלפוני אינטליגנטי בשירות הלקוחות. ענה בקצרה ובתמציתיות, שכן התשובה מוקראת למאזין בטלפון."
