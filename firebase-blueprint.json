{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A news flash or article.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Short headline" },
        "content": { "type": "string", "description": "Full content" },
        "imageUrl": { "type": "string", "description": "Optional image URL" },
        "categoryId": { "type": "string", "description": "ID of the category" },
        "authorId": { "type": "string", "description": "UID of the author" },
        "authorName": { "type": "string", "description": "Display name of the author" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp" },
        "isBreaking": { "type": "boolean", "description": "Is it a breaking news item?" },
        "emojis": {
          "type": "object",
          "description": "Emoji reactions counts",
          "properties": {
            "like": { "type": "integer" },
            "sad": { "type": "integer" },
            "wow": { "type": "integer" }
          }
        },
        "views": { "type": "integer", "description": "View count" }
      },
      "required": ["title", "content", "categoryId", "authorId", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A news category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name", "slug", "order"]
    },
    "User": {
      "title": "User",
      "description": "User profile and permissions.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"] },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global app settings.",
      "type": "object",
      "properties": {
        "tickerText": { "type": "string" },
        "isMaintenance": { "type": "boolean" },
        "siteTitle": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "News flashes"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "News categories"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/settings/global": {
      "schema": "Setting",
      "description": "Global configuration"
    }
  }
}
